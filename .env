FLASK_ENV=development
FLASK_SECRET_KEY=dev-secret

TRANSFORMERS_NO_TF=1
USE_TF=0

MYSQL_DATABASE=productdb
MYSQL_USER=app
MYSQL_ROOT_PASSWORD=admin123
MYSQL_PASSWORD=app
MYSQL_URL=mysql+pymysql://app:app@mysql:3306/productdb

PDF_UPLOAD_DIR=/data/pdfs
QDRANT_URL=http://qdrant:6333

NEO4J_USER=neo4j
NEO4J_PASSWORD=admin123
NEO4J_HTTP_HOST_PORT=7474
NEO4J_BOLT_HOST_PORT=7687
NEO4J_URI=bolt://neo4j:7687

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

MYSQL_HOST_PORT=3396
ADMINER_HOST_PORT=8980
QDRANT_HTTP_HOST_PORT=6333
QDRANT_GRPC_HOST_PORT=6334
APP_HOST_PORT=8080

OPENAI_API_KEY=
LLM_MODEL=gpt-4.1-mini
